{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TVP Scenario Instance Schema (English Canonical)",
  "type": "object",
  "required": [
    "instance_id",
    "scenario_uid",
    "macro_scene_id",
    "trust_level",
    "tau",
    "task_objective",
    "mni_baseline",
    "role_prompts"
  ],
  "properties": {
    "instance_id": {
      "type": "string"
    },
    "scenario_uid": {
      "type": "string",
      "pattern": "^S[1-3]-[1-9]$"
    },
    "macro_scene_id": {
      "type": "string",
      "enum": [
        "S1",
        "S2",
        "S3"
      ]
    },
    "macro_scene_name": {
      "type": "string"
    },
    "subscene_title": {
      "type": "string"
    },
    "trust_level": {
      "type": "string",
      "enum": [
        "no_trust",
        "low_trust",
        "high_trust"
      ]
    },
    "trust_label": {
      "type": "string"
    },
    "tau": {
      "type": "number",
      "enum": [
        0.1,
        0.5,
        0.9
      ]
    },
    "paper_level_alias": {
      "type": "string"
    },
    "trust_policy": {
      "type": "string"
    },
    "task_objective": {
      "type": "string"
    },
    "mni_baseline": {
      "type": "string"
    },
    "risk_focus": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "interaction_constraint": {
      "type": "object"
    },
    "role_prompts": {
      "type": "object",
      "minProperties": 2,
      "additionalProperties": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}